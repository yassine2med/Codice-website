    var header = $('.head-trans'); // Replace with your header class if different

    $(window).scroll(function() {
        if ($(this).scrollTop() > 50) { // Adjust the scroll distance
            header.addClass('scrolled');
        } else {
            header.removeClass('scrolled');
        }
    });
});

